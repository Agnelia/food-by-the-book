# Frontend Environment Variables Template
# Copy this file to .env.local and fill in with your actual values
# DO NOT commit .env.local to Git (it contains configuration that may be sensitive)

# Backend API URL (from Terraform output)
VITE_API_URL=https://func-foodbythebook-dev.azurewebsites.net/api

# Microsoft OAuth Configuration
# Get from: https://portal.azure.com → Entra ID → App Registrations → Your App
VITE_MSAL_CLIENT_ID=your-client-id-here
VITE_MSAL_TENANT_ID=your-tenant-id-here
VITE_MSAL_AUTHORITY=https://login.microsoftonline.com/your-tenant-id-here

# Optional: Environment indicator
VITE_ENVIRONMENT=development
